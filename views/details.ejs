<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="stylesheet" href="/css/general.css" />
    <link rel="stylesheet" href="/css/detail.css" />
    <title>Details</title>
  </head>
  <body class="app-container">
    <%- include("partials/header")%>
    <main class="main-container">
      <div class="detail-container">
        <!-- Logo -->
        <div
          id="headerGradient"
          class="music-logo-container flex flex-col md:flex-row h-auto md:h-[250px]"
        >
          <aside class="image-container">
            <img
              id="albumImage"
              src="/assets/MusicImg.jpg"
              alt="music image"
              class="w-[100%] h-auto md:w-[300px] md:h-[250px]"
            />
          </aside>
          <div class="text-container text p-2.5">
            <!--Image -->
            <div>
              <img
                class="profile-img"
                src="/assets/Palindrom_profile.jpg"
                alt="Profile Photo "
              />
            </div>
            <!--Artist Name -->
            <div class="logo-like-space">
              <div class="text-color">
                <p class="text-3xl font-semibold">Saoedade</p>
                <p class="text-xl">Palindrom</p>
              </div>
              <!--Like -->
            </div>
          </div>
          <div class="discription-container">
            <div class="artist-description p-5 text-color">
              <p>
                <em>
                  Stepan Burban is een Oekraïense rapper, zanger, componist,
                  regisseur en muziekproducer, beter bekend onder zijn
                  artiestennamen
                  <strong class="text-color">Kashlyayuchyi Ed</strong> en
                  <strong class="text-color">Palindrom</strong>.
                </em>
              </p>
            </div>
          </div>
        </div>

        <div class="main-gradient-container flex flex-row gap-[10px] pl-2.5">
          <button>
            <img
              src="/assets/playButton.png"
              alt="Play button"
              class="m-12 h-12 play-btn"
            />
          </button>
          <button>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-12 h-12 play-btn"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 4.5v15m7.5-7.5h-15"
              />
            </svg>
          </button>
          <button>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-12 h-12 play-btn"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"
              />
            </svg>
          </button>
          <button>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-12 h-12 play-btn"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM12.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM18.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"
              />
            </svg>
          </button>
        </div>
        <!--Recommended -->
        <div class="recommended-section">
          <div class="rec-header">
            <p class="font-semibold">Meer van deze auteur</p>
            <img
              src="/assets/arrow-down.png"
              alt="arrow-down"
              class="rec-icon"
            />
          </div>

          <div class="rec-container main-gradient-container" id="songs">
            <% for(var i= 0; i < 5; i++) { %>
            <aside class="rec-music text-container w-full">
              <div>
                <img
                  src="/assets/Palindrom_profile.jpg"
                  alt="profile img"
                  class="rec-profile-img"
                />
              </div>
              <div class="flex flex-row justify-between w-full">
                <div>
                  <h2 class="font-semibold text-2xl">
                    <a href="/details">Saoedade</a>
                  </h2>
                  <p class="text-xl">
                    <a href="/details">Palindrom</a>
                  </p>
                </div>
                <div class="flex flex-row justify-center items-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="rec-like play-btn"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"
                    />
                  </svg>

                  <span>50</span>
                </div>
              </div>
            </aside>
            <% } %>
          </div>

          <div class="rec-header">
            <p class="font-semibold">Ontdek nieuwe muziek</p>
            <img
              src="/assets/arrow-down.png"
              alt="arrow-down"
              class="rec-icon"
            />
          </div>

          <div class="rec-container main-gradient-container">
            <% for(var i= 0; i < 5; i++) { %>
            <aside class="rec-music text-container w-full">
              <div>
                <img
                  src="/assets/Palindrom_profile.jpg"
                  alt="profile img"
                  class="rec-profile-img"
                />
              </div>
              <div class="flex flex-row justify-between w-full">
                <div>
                  <h2 class="font-semibold text-2xl">
                    <a href="/details">Saoedade</a>
                  </h2>
                  <p class="text-xl">
                    <a href="/details">Palindrom</a>
                  </p>
                </div>
                <div class="flex flex-row justify-center items-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="rec-like play-btn"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"
                    />
                  </svg>

                  <span>50</span>
                </div>
              </div>
            </aside>
            <% } %>
          </div>
        </div>
      </div>
    </main>
    <%- include("partials/footer")%>
    <script src="/js/gradient.js"></script>
  </body>
</html>
