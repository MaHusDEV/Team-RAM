<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="stylesheet" href="/css/general.css" />
    <title>Home</title>
  </head>
  <body class="app-container">
    <%- include("partials/header")%>
    
    <main class="main-container">
      <div class="logo flex flex-row justify-center items-center h-[250px]">
        <p class="text-6xl font-semibold intro">Ontdek een nieuwe wereld van muziek met MusixMatch</p>
      </div>

      <div
        class=" flex flex-col md:flex-row h-max pt-5"
      >
        <div class="flex flex-col md:w-[50%] md:max-w-[50%]">
          <p class="text-2xl pl-5 font-semibold intro">Ga er weer mee verder</p>
          <div class=" grid grid-cols-1 md:grid-cols-2 gap-4 p-5">
            <%
              const shuffled = [...songs].sort(() => Math.random() - 0.5);
              const firstBlock = shuffled.slice(0, 4);
              const secondBlock = shuffled.slice(4, 8);
              const genreBlock = shuffled.slice(8, 20);
            %>
            <% firstBlock.forEach((song) => { %>
            <%- include("partials/songoverview" ,{ song: song })%>
            <% });  %>
          </div>
        </div>
        <div class="flex flex-col md:w-[50%] md:max-w-[50%]">
          <p class="text-2xl pl-5 font-semibold intro">Populair voor jou</p>
          <div class=" grid grid-cols-1 md:grid-cols-2 gap-4 p-5">
            <% secondBlock.forEach((song) => { %>
            <%- include("partials/songoverview" ,{ song: song })%>
            <% });  %>
          </div>
        </div>
      </div>
      <p class="text-2xl pl-5 font-semibold intro">Trending per genre</p>
      <div class=" h-max p-5 min-w-0">
        <div class="genres genre-scroll">
          <% ["All","Jazz","Rock","Hip Hop"].forEach(g => { %>
            <a 
              href="/?q=<%= query || '' %>&genre=<%= g %>&sort=<%= sort || 'popular' %>"
              class="genre <%= genre === g ? 'active' : '' %>"
            >
              <%= g %>
            </a>
          <% }) %>
        </div>
        <div class="trend-con">
          <%
            const shuffledTrending = [...trendingSongs].sort(() => Math.random() - 0.5);
            const finalTrending = shuffledTrending.slice(0, 12);
          %>
          <% if (finalTrending && finalTrending.length > 0) { %>
            <% finalTrending.forEach((song) => { %>
              <%- include("partials/songoverview", { song }) %>
            <% }) %>
          <% } else { %>
          <p class="pt-5 text-xl intro">Geen resultaten gevonden</p>
          <% } %>
        </div>
      </div>
      <p class="text-2xl pl-5 font-semibold intro">Albums voor jou</p>
      <div class="album-con">
        
        <div
          class="rec-music-gradient w-56 rounded-xl shadow-md overflow-hidden hover:shadow-xl transition"
        >
          <img
            src="/assets/chillvibes.jpg"
            class="w-full h-36 object-cover"
            alt="album img"
          />
          <div class="p-4">
            <h2 class="font-semibold text-2xl">Late Night</h2>
            <p class="text-sm text-xl">Night vibes</p>
          </div>
        </div>
      </div>  
    </main>
    <%- include("partials/footer")%>
  </body>
</html>
