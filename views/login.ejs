<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="stylesheet" href="/css/general.css" />
    <link rel="stylesheet" href="/css/LoginHandler.css" />
    <title>Inloggen</title>
  </head>

  <body class="app-container">
    <%- include("partials/header")%>

    <main class="main-container flex flex-col items-center">
      <div
        class="login-container main-gradient-container w-[400px] h-[340px] p-6 rounded-xl shadow-xl"
      >
        <h2 class="flex justify-center items-center text-2xl">Log in</h2>

        <form
          action="/login"
          method="post"
          class="flex flex-col gap-4 mt-4 h-full"
        >
          <div class="input-margin">
            <label for="username">Naam</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Andriy"
              required
              class="w-full p-2 rounded-md focus:outline-none focus:ring-2"
            />
          </div>
          <div>
            <label for="password">Wachtwoord</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Voer je wachtwoord in"
              required
              class="w-full p-2 rounded-md focus:outline-none focus:ring-2"
            />
          </div>

          <div class="flex flex-col justify-center items-center mt-4 log-btn">
            <a href="/register">Nog geen account? Maak er een aan.</a>
            <button class="btn" type="submit">Log in</button>
          </div>
        </form>
      </div>
    </main>

    <%- include("partials/footer")%>
  </body>
</html>
